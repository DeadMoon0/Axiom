<UserControl x:Class="Axiom.Wpf.Sample.UserControls.MessagesView.UC_MessagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Axiom.Wpf.Sample.UserControls.MessagesView"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer x:Name="svMessage" VerticalScrollBarVisibility="Auto" ScrollChanged="svMessage_ScrollChanged">
            <StackPanel x:Name="spMessages" MaxWidth="800">
                
            </StackPanel>
        </ScrollViewer>
        <Grid Grid.Row="1" Margin="2.5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="tbMessage"></TextBox>
            <Button x:Name="btSend" Grid.Column="1" Margin="10 0 0 0" Click="btSend_Click">Send</Button>
        </Grid>
    </Grid>
</UserControl>