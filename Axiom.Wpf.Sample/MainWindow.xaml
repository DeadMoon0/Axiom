<Window x:Class="Axiom.Wpf.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Axiom.Wpf.Sample"
        xmlns:messagesView="clr-namespace:Axiom.Wpf.Sample.UserControls.MessagesView"
        mc:Ignorable="d"
        Title="MainWindow" Background="#FF323232" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="5">
            <StackPanel x:Name="spUsers">
                
            </StackPanel>
        </ScrollViewer>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="5">
            <Border x:Name="o1" Height="10" Width="10" Background="Green" Margin="5"/>
            <Border x:Name="o2" Height="10" Width="10" Background="Green" Margin="5"/>
            <Border x:Name="o3" Height="10" Width="10" Background="Green" Margin="5"/>
            <Border x:Name="oS" Height="10" Width="10" Background="Green" Margin="5"/>
        </StackPanel>
        <Grid Grid.Column="1">
            <TextBlock x:Name="tbSAU" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray">Select A User</TextBlock>
            <messagesView:UC_MessagesView x:Name="messageView"/>
        </Grid>
    </Grid>
</Window>
